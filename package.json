{
  "name": "claudebin-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/plugin/mcp"
  ],
  "scripts": {
    "dev": "bun --filter web dev",
    "build": "bun --filter '*' build",
    "cli": "bun --filter cli dev",
    "plugin": "bun --filter claudebin-mcp dev",
    "type-check": "bun --filter '*' type-check",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "husky": "^9.1.7",
    "typescript": "^5.3.0"
  }
}
