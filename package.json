{
  "name": "claudebin-monorepo",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*",
    "packages/plugin/mcp"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=claudebin-web",
    "build": "turbo run build",
    "plugin": "turbo run dev --filter=claudebin-mcp",
    "type-check": "turbo run type-check",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/lodash.truncate": "^4.4.9",
    "husky": "^9.1.7",
    "turbo": "^2.7.5",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "lodash.truncate": "^4.4.2",
    "remark-gfm": "^4.0.1",
    "web": "^0.0.2"
  }
}
